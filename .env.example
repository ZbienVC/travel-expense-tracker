# Database
DATABASE_URL="postgresql://user:password@localhost:5432/travel_expense_tracker"

# Google APIs
GOOGLE_VISION_KEY_PATH="./secrets/google-vision-key.json"
GOOGLE_VISION_PROJECT_ID="your-gcp-project-id"
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Server
NODE_ENV="development"
PORT=3000
API_URL="http://localhost:3000"

# Frontend
VITE_API_URL="http://localhost:3000"
VITE_MAPS_API_KEY="your-google-maps-api-key"

# Rate Limiting & Cost Control
GOOGLE_VISION_RATE_LIMIT_PER_HOUR=1000
GOOGLE_MAPS_RATE_LIMIT_PER_HOUR=25000
COST_LIMIT_MONTHLY_USD=100

# Optional: Monitoring & Logging
LOG_LEVEL="info"
SENTRY_DSN=""

# Optional: Authentication
JWT_SECRET="your-jwt-secret-key"
AUTH_ENABLED=false
