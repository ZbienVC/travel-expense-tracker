{
  "name": "travel-expense-tracker",
  "version": "0.1.0",
  "description": "AI-powered travel expense tracking with receipt OCR and trip analytics",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx watch src/server/index.ts",
    "dev:frontend": "vite",
    "dev:mobile": "expo start",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc --noEmit && vite build --mode lib",
    "build:frontend": "vite build",
    "start": "node dist/server/index.js",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx src/server/seeds/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest",
    "test:backend": "vitest src/server",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "deploy": "node scripts/deploy.js",
    "deploy:qr": "node scripts/generate-qr.js"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@google-cloud/vision": "^4.0.0",
    "@googlemaps/js-api-loader": "^1.16.0",
    "axios": "^1.6.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "express-cors": "^0.2.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0",
    "rate-limiter-flexible": "^2.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.16.0",
    "recharts": "^2.10.0",
    "expo": "^50.0.0",
    "expo-constants": "^15.0.0",
    "expo-device": "^5.4.0",
    "expo-camera": "^13.4.0",
    "react-native": "^0.73.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.54.0",
    "prisma": "^6.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "qrcode": "^1.5.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
